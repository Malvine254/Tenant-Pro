RewriteEngine On

# Canonical host
RewriteCond %{HTTP_HOST} ^www\.starmaxltd\.com$ [NC]
RewriteRule ^ http://starmaxltd.com%{REQUEST_URI} [L,R=301]

# Keep Let's Encrypt validation working if enabled
RewriteRule ^\.well-known/ - [L]

# Proxy API traffic to NestJS backend (port 3000)
RewriteRule ^api/(.*)$ http://127.0.0.1:3000/api/$1 [P,L,QSA]

# Proxy all other traffic to Next.js app (port 3001)
RewriteRule ^(.*)$ http://127.0.0.1:3001/$1 [P,L,QSA]

# Forward protocol information to upstream apps
RewriteCond %{HTTPS} on
RewriteRule ^ - [E=FORWARDED_PROTO:https,E=FORWARDED_PORT:443]
RewriteCond %{HTTPS} !=on
RewriteRule ^ - [E=FORWARDED_PROTO:http,E=FORWARDED_PORT:80]
RequestHeader set X-Forwarded-Proto %{FORWARDED_PROTO}e env=FORWARDED_PROTO
RequestHeader set X-Forwarded-Port %{FORWARDED_PORT}e env=FORWARDED_PORT