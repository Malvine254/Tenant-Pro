<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="12dp"
        android:layout_marginHorizontal="10dp"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/primary_variant">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilSearch"
            style="@style/Theme.TenantPro.TextInputLayout.Search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:hint="Search invoices"
            app:startIconDrawable="@drawable/ic_search"
            app:startIconMinSize="16dp"
            app:endIconMode="custom"
            app:endIconDrawable="@drawable/ic_mic"
            app:endIconMinSize="16dp"
            app:endIconContentDescription="Voice search"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="0dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:singleLine="true"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:maxLines="1"
                android:textSize="14sp"
                android:textColor="@color/on_surface"
                android:textColorHint="@color/on_surface_variant"
                android:background="@android:color/transparent" />
        </com.google.android.material.textfield.TextInputLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Table column header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/primary"
        android:paddingHorizontal="12dp">

        <TextView
            android:layout_width="26dp"
            android:layout_height="wrap_content"
            android:text="@string/invoice_table_header_no"
            android:textColor="@color/on_primary"
            android:textSize="10sp"
            android:textAllCaps="true"
            android:gravity="center"
            android:letterSpacing="0.06" />

        <TextView
            android:id="@+id/tvHeaderInvoiceSort"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/invoice_table_header_invoice_desc"
            android:textColor="@color/on_primary"
            android:textSize="10sp"
            android:textAllCaps="true"
            android:letterSpacing="0.06"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:paddingVertical="4dp" />

        <TextView
            android:layout_width="84dp"
            android:layout_height="wrap_content"
            android:text="@string/invoice_table_header_amount"
            android:textColor="@color/on_primary"
            android:textSize="10sp"
            android:textAllCaps="true"
            android:gravity="end"
            android:letterSpacing="0.06" />

        <TextView
            android:layout_width="66dp"
            android:layout_height="wrap_content"
            android:text="@string/invoice_table_header_status"
            android:textColor="@color/on_primary"
            android:textSize="10sp"
            android:textAllCaps="true"
            android:gravity="center"
            android:letterSpacing="0.06" />

        <TextView
            android:layout_width="98dp"
            android:layout_height="wrap_content"
            android:text="@string/invoice_table_header_actions"
            android:textColor="@color/on_primary"
            android:textSize="10sp"
            android:textAllCaps="true"
            android:gravity="center"
            android:letterSpacing="0.06" />

    </LinearLayout>

    <!-- ── Invoice rows ─────────────────────────────────────────── -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvInvoices"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="8dp" />

            <!-- Empty state -->
            <LinearLayout
                android:id="@+id/tvEmpty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_receipt"
                    android:tint="@color/on_surface_variant"
                    android:alpha="0.4"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/no_invoices"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your invoices will appear here."
                    android:textSize="13sp"
                    android:textColor="@color/on_surface_variant"
                    android:gravity="center"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Error state -->
            <LinearLayout
                android:id="@+id/tvError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_info"
                    android:tint="@color/error"
                    android:alpha="0.7"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvErrorMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/error"
                    android:gravity="center" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRetry"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Try again"
                    android:layout_marginTop="12dp" />
            </LinearLayout>

        </FrameLayout>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <LinearLayout
        android:id="@+id/paginationBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="14dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="6dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPrevPage"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/invoice_prev" />

        <TextView
            android:id="@+id/tvPageIndicator"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/on_surface"
            android:textSize="12sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNextPage"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/invoice_next" />
    </LinearLayout>

</LinearLayout>
