<?xml version="1.0" encoding="utf-8"?>
<!--
  Tabular invoice row:
  [Type + Period (flex)] | [Amount+Paid] | [Status] | [⬇ Pay ⓘ]
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:background="@color/surface">

        <!-- Col 0: Row number -->
        <TextView
            android:id="@+id/tvRowNumber"
            android:layout_width="26dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/on_surface_variant"
            android:textSize="11sp"
            android:textStyle="bold" />

        <!-- Col 1: Type + Period  (flex) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvBillingType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/on_surface"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPeriod"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/on_surface_variant"
                android:textSize="11sp"
                android:layout_marginTop="1dp" />

            <TextView
                android:id="@+id/tvProperty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/on_surface_variant"
                android:textSize="10sp"
                android:layout_marginTop="1dp"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Col 2: Total / Paid (88dp) -->
        <LinearLayout
            android:layout_width="84dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/on_surface"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="end" />

            <TextView
                android:id="@+id/tvPaid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/success"
                android:textSize="10sp"
                android:gravity="end"
                android:layout_marginTop="1dp" />

            <TextView
                android:id="@+id/tvDue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/on_surface_variant"
                android:textSize="10sp"
                android:gravity="end"
                android:layout_marginTop="1dp" />

        </LinearLayout>

        <!-- Col 3: Status badge (60dp) -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:paddingHorizontal="4dp"
            android:paddingVertical="3dp"
            android:gravity="center"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textAllCaps="true" />

        <!-- Col 4: Actions (Save + Pay) -->
        <LinearLayout
            android:layout_width="98dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginStart="2dp"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                style="@style/Theme.TenantPro.Button.RowActionSecondary"
                android:layout_width="44dp"
                android:layout_height="32dp"
                android:text="@string/invoice_action_save"
                android:contentDescription="Save invoice" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPay"
                style="@style/Theme.TenantPro.Button.RowActionPrimary"
                android:layout_width="44dp"
                android:layout_height="32dp"
                android:layout_marginStart="4dp"
                android:text="@string/invoice_action_pay"
                android:contentDescription="Pay invoice" />

        </LinearLayout>

    </LinearLayout>

    <!-- Thin divider between rows -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/primary_variant" />

</LinearLayout>
