<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Topic dropdown -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilQueryTopic"
        style="@style/Theme.TenantPro.TextInputLayout.ExposedDropdown"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="4dp">

        <com.google.android.material.textfield.MaterialAutoCompleteTextView
            android:id="@+id/actQueryTopic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="none"
            android:textColor="@color/on_surface"
            android:textSize="14sp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- ── Chat list ──────────────────────────────────────────── -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvChats"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/tvEmptyChats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/queries_empty_chat"
            android:textColor="@color/on_surface_variant"
            android:textSize="13sp"
            android:visibility="gone" />
    </FrameLayout>

    <!-- ── Compose bar ───────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface"
        android:paddingHorizontal="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="8dp"
        android:elevation="8dp">

        <!-- Attachment preview chip (visible when a file is selected) -->
        <LinearLayout
            android:id="@+id/layoutAttachmentPreview"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="4dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_file"
                android:tint="@color/secondary" />

            <TextView
                android:id="@+id/tvAttachmentPreview"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="6dp"
                android:textColor="@color/on_surface"
                android:textSize="12sp"
                android:singleLine="true"
                android:ellipsize="middle" />

            <ImageButton
                android:id="@+id/btnClearAttachment"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_close_small"
                android:padding="2dp"
                android:tint="@color/on_surface_variant"
                android:contentDescription="Remove attachment" />
        </LinearLayout>

        <!-- Message compose row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Message input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilQueryMessage"
                style="@style/Theme.TenantPro.TextInputLayout.Search"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/query_message_hint_chat"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="0dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etQueryMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:minLines="1"
                    android:maxLines="4"
                    android:inputType="textCapSentences"
                    android:textSize="14sp"
                    android:textColor="@color/on_surface"
                    android:textColorHint="@color/on_surface_variant"
                    android:imeOptions="actionSend"
                    android:background="@android:color/transparent" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Send button -->
            <ImageButton
                android:id="@+id/btnSendMessage"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_circle_primary"
                android:src="@drawable/ic_send"
                android:padding="10dp"
                android:scaleType="fitCenter"
                android:contentDescription="Send message"
                android:tint="@color/on_primary" />

            <!-- Attachment button -->
            <ImageButton
                android:id="@+id/btnAttachment"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="6dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_attachment"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:contentDescription="Attach file"
                android:tint="@color/on_surface_variant" />

        </LinearLayout>
    </LinearLayout>

</LinearLayout>