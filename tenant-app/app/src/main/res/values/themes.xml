<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base Material 3 theme -->
    <style name="Theme.TenantPro" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorOutline">@color/on_surface_variant</item>
        <item name="colorError">@color/error</item>
        <item name="materialButtonOutlinedStyle">@style/Theme.TenantPro.Button.Outlined</item>
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">true</item>
        <!-- Splash screen attribute (androidx.core:core-splashscreen) -->
        <item name="android:windowSplashScreenBackground">@color/background</item>
    </style>

    <!-- Splash screen theme set via installSplashScreen() in MainActivity -->
    <style name="Theme.TenantPro.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.TenantPro</item>
    </style>

    <!-- Enhanced TextInputLayout with modern focus state -->
    <style name="Theme.TenantPro.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/text_input_box_stroke</item>
        <item name="boxStrokeWidth">2dp</item>
        <item name="boxStrokeWidthFocused">2.5dp</item>
        <item name="boxBackgroundColor">@color/surface</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="hintTextColor">@color/on_surface_variant</item>
        <item name="counterTextColor">@color/on_surface_variant</item>
    </style>

    <style name="Theme.TenantPro.TextInputLayout.Auth" parent="Theme.TenantPro.TextInputLayout">
        <item name="boxStrokeColor">@color/primary_variant</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
    </style>

    <style name="Theme.TenantPro.TextInputLayout.Search" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxStrokeColor">@android:color/transparent</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">0dp</item>
        <item name="boxBackgroundColor">@android:color/transparent</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="hintTextColor">@color/on_surface_variant</item>
        <item name="startIconTint">@color/on_surface_variant</item>
        <item name="endIconTint">@color/on_surface_variant</item>
        <item name="startIconMinSize">16dp</item>
        <item name="endIconMinSize">16dp</item>
    </style>

    <style name="Theme.TenantPro.TextInputEditText" parent="Widget.Material3.TextInputEditText.OutlinedBox">
        <item name="android:minHeight">56dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textColorHint">@color/on_surface_variant</item>
    </style>

    <style name="Theme.TenantPro.TextInputLayout.ExposedDropdown" parent="Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxStrokeColor">@color/primary</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxBackgroundColor">@color/surface</item>
        <item name="hintTextColor">@color/on_surface_variant</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="endIconTint">@color/primary</item>
    </style>

    <style name="Theme.TenantPro.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/button_outlined_stroke</item>
        <item name="strokeWidth">1.25dp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Theme.TenantPro.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:elevation">0dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Theme.TenantPro.Button.RowActionPrimary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:minHeight">32dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingLeft">0dp</item>
        <item name="android:paddingRight">0dp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">10sp</item>
        <item name="android:elevation">0dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Theme.TenantPro.Button.RowActionSecondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/primary_variant</item>
        <item name="strokeWidth">1dp</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:minHeight">32dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingLeft">0dp</item>
        <item name="android:paddingRight">0dp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">10sp</item>
        <item name="android:elevation">0dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Theme.TenantPro.Card.Form" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@android:color/white</item>
        <item name="backgroundTint">@android:color/white</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">16dp</item>
        <item name="cardUseCompatPadding">true</item>
        <item name="contentPadding">4dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

</resources>
